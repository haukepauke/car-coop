# ── Test environment overrides ────────────────────────────────────────────────
# SQLite keeps tests self-contained and fast. The schema is recreated from
# Doctrine metadata in tests/bootstrap.php on every test-suite run.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/test.db"

# Reuse the JWT keys generated for dev (created by docker-entrypoint.sh).
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=f79ffbc5156345f27d668b1030d9736ec5eb58c0e2248b04aea2dae8bd8898d7

# Silence the mailer so no real e-mails are sent during tests.
MAILER_DSN=null://null
