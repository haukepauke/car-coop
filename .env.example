# ── Car Coop — production environment template ────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#   nano .env
#   docker compose -f docker-compose.prod.yml up -d

# ── App ───────────────────────────────────────────────────────────────────────
# Generate a random 32-char string, e.g.:
#   openssl rand -hex 16
APP_SECRET=changeme_generate_a_random_32char_string

# Port to expose on the host (default: 80)
HTTP_PORT=80

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=carcoop
DB_USER=carcoop
DB_PASSWORD=changeme_strong_db_password
DB_ROOT_PASSWORD=changeme_strong_root_password

# ── Mail (optional) ───────────────────────────────────────────────────────────
# Leave MAILER_DSN as null://null to disable outgoing email.
# SMTP example:  smtp://user:pass@smtp.example.com:587
# Gmail example: gmail+smtp://user:app_password@default
MAILER_DSN=null://null
MAILER_FROM_EMAIL=noreply@example.com
MAILER_FROM_NAME="Car Coop"

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_HOMEPAGE_URL=https://example.com

# ── Sentry error tracking (optional) ─────────────────────────────────────────
# Leave empty to disable.
SENTRY_DSN=
