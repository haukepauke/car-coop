{% extends 'email/base.html.twig' %}

{% block content %}
<p><b>{{ 'event_email.booking.deleted_for'|trans({'%car%': car.name}) }}</b></p>

<p>{{ 'event_email.booking.deleted_by'|trans({'%user%': bookerName, '%car%': car.name}) }}</p>

<table class="data-table" style="margin:16px 0;">
    <tr>
        <th>{{ 'booking.form.title'|trans }}:</th>
        <td>{{ title }}</td>
    </tr>
    <tr>
        <th>{{ 'date.start'|trans }}:</th>
        <td>{{ startDate }}</td>
    </tr>
    <tr>
        <th>{{ 'date.end'|trans }}:</th>
        <td>{{ endDate }}</td>
    </tr>
</table>
{% endblock %}
