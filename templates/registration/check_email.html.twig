{% extends 'blank.html.twig' %}

{% block title %}{{ 'registration.check_email.title'|trans }}{% endblock %}

{% block body %}
<section class="vh-100" style="background-color: #ddd;">
  <div class="container h-100">
    <div class="row d-flex justify-content-center align-items-center h-100">
      <div class="col-12 col-md-8 col-lg-6 col-xl-5">
        <div class="card shadow-2-strong" style="border-radius: 1rem;">
          <div class="card-body p-5 text-center">

            <img class="rounded-circle mb-3" src="{{ asset('/build/static/default-car.png')|imagine_filter('profile_thumb') }}" height="100" width="100">
            <h3 class="mb-4">Car Coop</h3>
            <h4 class="mb-3">{{ 'registration.check_email.title'|trans }}</h4>

            {% if email %}
              <p class="mb-1">{{ 'registration.check_email.message'|trans({'%email%': email}) }}</p>
            {% else %}
              <p class="mb-1">{{ 'registration.check_email.message_generic'|trans }}</p>
            {% endif %}
            <p class="text-muted small mb-4">{{ 'registration.check_email.spam_hint'|trans }}</p>

            {% if email %}
            <form method="post" action="{{ path('app_resend_verification') }}" class="mb-4">
              <input type="hidden" name="_token" value="{{ csrf_token('resend_verification') }}">
              <input type="hidden" name="email" value="{{ email }}">
              <button type="submit" class="btn btn-dark btn-lg btn-block w-100">{{ 'registration.check_email.resend'|trans }}</button>
            </form>
            {% endif %}

            <a href="{{ path('app_login') }}" class="text-muted small">{{ 'registration.check_email.login_link'|trans }}</a>

          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
