{% extends 'blank.html.twig' %}

{% block title %}{{ 'user.register'|trans }}{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            const storageKey = 'registration-locale-form-state';

            const restoreState = () => {
                const form = document.querySelector('form[data-registration-form]');
                if (!form) {
                    return;
                }

                const rawState = window.sessionStorage.getItem(storageKey);
                if (!rawState) {
                    return;
                }

                window.sessionStorage.removeItem(storageKey);

                try {
                    const state = JSON.parse(rawState);
                    const email = form.querySelector('[data-registration-email]');
                    const name = form.querySelector('[data-registration-name]');
                    const locale = form.querySelector('[data-registration-locale]');
                    const agreeTerms = form.querySelector('[data-registration-agree-terms]');

                    if (email && !email.disabled && typeof state.email === 'string') {
                        email.value = state.email;
                    }

                    if (name && typeof state.name === 'string') {
                        name.value = state.name;
                    }

                    if (locale && typeof state.locale === 'string') {
                        locale.value = state.locale;
                    }

                    if (agreeTerms && typeof state.agreeTerms === 'boolean') {
                        agreeTerms.checked = state.agreeTerms;
                    }
                } catch (error) {
                    window.sessionStorage.removeItem(storageKey);
                }
            };

            document.addEventListener('DOMContentLoaded', () => {
                const form = document.querySelector('form[data-registration-form]');
                if (!form) {
                    return;
                }

                restoreState();

                const localeSelect = form.querySelector('[data-registration-locale]');
                if (!localeSelect) {
                    return;
                }

                localeSelect.addEventListener('change', () => {
                    const email = form.querySelector('[data-registration-email]');
                    const name = form.querySelector('[data-registration-name]');
                    const agreeTerms = form.querySelector('[data-registration-agree-terms]');

                    const state = {
                        locale: localeSelect.value,
                        email: email && !email.disabled ? email.value : null,
                        name: name ? name.value : null,
                        agreeTerms: agreeTerms ? agreeTerms.checked : null,
                    };

                    window.sessionStorage.setItem(storageKey, JSON.stringify(state));

                    const url = new URL(window.location.href);
                    url.searchParams.set('ui_locale', localeSelect.value);
                    window.location.assign(url.toString());
                });
            });
        })();
    </script>
{% endblock %}

{% block body %}
<section class="auth-shell" style="min-height: 100vh; padding: 1.5rem 0;">
  <div class="container">
    <div class="row d-flex justify-content-center">
      <div class="col-12 col-md-8 col-lg-6 col-xl-5">
        <div class="card shadow-2-strong" style="border-radius: 1rem;">
          <div class="card-body p-4 text-center">

            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {% include 'auth/_header.html.twig' %}
            <h1 class="h4 mb-3">{{ 'registration.form.headline'|trans }}</h1>

            {{ form_start(registrationForm, {
              attr: {
                'data-registration-form': true
              }
            }) }}
            {# Honeypot field: hidden from real users, bots fill it in #}
            <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;">
                {{ form_row(registrationForm.website) }}
            </div>
            <div class="form-group mb-2 text-start">
                {{ form_label(registrationForm.email, null, {
                  label_attr: {
                    class: 'form-label'
                  }
                }) }}
                {{ form_widget(registrationForm.email, {
                  attr: {
                    'data-registration-email': true
                  }
                }) }}
                {{ form_errors(registrationForm.email) }}
            </div>
            <div class="form-group mb-2 text-start">
                {{ form_label(registrationForm.name, null, {
                  label_attr: {
                    class: 'form-label'
                  }
                }) }}
                {{ form_widget(registrationForm.name, {
                  attr: {
                    'data-registration-name': true
                  }
                }) }}
                {{ form_errors(registrationForm.name) }}
            </div>
            <div class="form-group mb-2 text-start">
                {{ form_label(registrationForm.locale, null, {
                  label_attr: {
                    class: 'form-label'
                  }
                }) }}
                {{ form_widget(registrationForm.locale, {
                  attr: {
                    'data-registration-locale': true
                  }
                }) }}
                {{ form_errors(registrationForm.locale) }}
            </div>
            <div class="form-group mb-2 text-start">
                {{ form_label(registrationForm.plainPassword, null, {
                  label_attr: {
                    class: 'form-label'
                  }
                }) }}
                {{ form_widget(registrationForm.plainPassword) }}
                {{ form_errors(registrationForm.plainPassword) }}
            </div>
            <div class="form-check mb-2 text-start">
                {{ form_widget(registrationForm.agreeTerms, {
                  'label_html': true,
                  attr: {
                    'data-registration-agree-terms': true
                  }
                }) }}
            </div>
            <button type="submit" class="btn btn-dark btn-lg btn-block w-100 mt-2">{{ 'user.register'|trans }}</button>
            {{ form_end(registrationForm) }}

          </div>
        </div>
        <div class="auth-links text-center d-flex justify-content-center gap-4">
            <a href="{{ path('app_login', {'_locale': app.request.locale}) }}">{{ 'registration.form.have_account'|trans }}</a>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
