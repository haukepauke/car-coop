{% extends 'blank.html.twig' %}

{% block title %}{{ 'user.register'|trans }}{% endblock %}

{% block body %}
<section style="background-color: #ddd; min-height: 100vh; padding: 1.5rem 0;">
  <div class="container">
    <div class="row d-flex justify-content-center">
      <div class="col-12 col-md-8 col-lg-6 col-xl-5">
        <div class="card shadow-2-strong" style="border-radius: 1rem;">
          <div class="card-body p-4 text-center">

            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {% include 'auth/_header.html.twig' %}
            <h4 class="mb-3">{{ 'registration.form.headline'|trans }}</h4>

            {{ form_start(registrationForm) }}
            {# Honeypot field: hidden from real users, bots fill it in #}
            <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;">
                {{ form_row(registrationForm.website) }}
            </div>
            <div class="form-group mb-2 text-start">
                <label>{{ form_label(registrationForm.email) }}</label>
                {{ form_widget(registrationForm.email) }}
                {{ form_errors(registrationForm.email) }}
            </div>
            <div class="form-group mb-2 text-start">
                <label>{{ form_label(registrationForm.name) }}</label>
                {{ form_widget(registrationForm.name) }}
                {{ form_errors(registrationForm.name) }}
            </div>
            <div class="form-group mb-2 text-start">
                <label>{{ form_label(registrationForm.locale) }}</label>
                {{ form_widget(registrationForm.locale) }}
                {{ form_errors(registrationForm.locale) }}
            </div>
            <div class="form-group mb-2 text-start">
                <label>{{ 'password'|trans }}</label>
                {{ form_widget(registrationForm.plainPassword) }}
                {{ form_errors(registrationForm.plainPassword) }}
            </div>
            <div class="form-check mb-2 text-start">
                {{ form_widget(registrationForm.agreeTerms, {'label_html': true}) }}
            </div>
            <button type="submit" class="btn btn-dark btn-lg btn-block w-100 mt-2">{{ 'user.register'|trans }}</button>
            {{ form_end(registrationForm) }}

          </div>
        </div>
        <div class="text-center d-flex justify-content-center gap-4">
            <a href="{{ path('app_login') }}">{{ 'registration.form.have_account'|trans }}</a>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
