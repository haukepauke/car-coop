{% extends 'blank.html.twig' %}

{% block title %}{{ 'log.forgot_password'|trans }}{% endblock %}

{% block body %}
<section class="vh-100" style="background-color: #ddd;">
  <div class="container h-100">
    <div class="row d-flex justify-content-center align-items-center h-100">
      <div class="col-12 col-md-8 col-lg-6 col-xl-5">
        <div class="card shadow-2-strong" style="border-radius: 1rem;">
          <div class="card-body p-4 text-center">

            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {% include 'auth/_header.html.twig' %}
            <h4 class="mb-3">{{ 'log.forgot_password'|trans }}</h4>

            {{ form_start(requestForm) }}
              {# Honeypot field: hidden from real users, bots fill it in #}
              <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;">
                  {{ form_row(requestForm.website) }}
              </div>
              <div class="form-outline mb-2 text-start">
                  {{ form_row(requestForm.email) }}
              </div>
              <p class="text-muted small mb-3">Enter your email address and we will send you a link to reset your password.</p>
              <button class="btn btn-dark btn-lg btn-block w-100">Send password reset email</button>
            {{ form_end(requestForm) }}

            <a href="{{ path('app_login') }}" class="text-muted small mt-3 d-block">{{ 'registration.check_email.login_link'|trans }}</a>

          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
