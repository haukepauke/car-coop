<!DOCTYPE html>
{% set currentTheme = is_granted('IS_AUTHENTICATED_REMEMBERED') and app.user ? app.user.themePreference : 'classic' %}
<html lang="{{ app.request.locale|default('en') }}" data-theme="{{ currentTheme }}">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    {% block stylesheets %}
    {{ ux_controller_link_tags() }}
    {% endblock %}

    {% block javascripts %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body>
    <div class="container-fluid">
        <header>
            <nav class="navbar navbar-expand-lg fixed-top" data-bs-theme="dark">
                <div class="container-fluid">
                    <a class="navbar-brand" href="{{ is_granted('IS_AUTHENTICATED_REMEMBERED') ? path('app_car_show') : '#' }}">
                        {%if is_granted('IS_AUTHENTICATED_REMEMBERED') and car is defined %}
                        {% if car.profilePicturePath|default %}
                        <img id="navbar-brand-img" src="{{ asset('/uploads/cars/' ~ car.getProfilePicturePath())|imagine_filter('profile_thumb') }}" alt="" width="50"
                            height="50" class="rounded-circle d-inline-block">
                        {% else %}
                        <img id="navbar-brand-img" src="{{ asset('./static/default-car.png') }}" alt="" width="50" height="50"
                            class="rounded-circle d-inline-block">
                        {% endif %}
                        <span id="navbar-brand-name">{{ car.name }}</span>
                        {% else %}
                        <img id="navbar-brand-img" src="{{ asset('./static/default-car.png') }}" alt="" width="50" height="50"
                            class="rounded-circle d-inline-block">
                        <span id="navbar-brand-name">Car Coop</span>
                        {% endif %}
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false"
                        aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNavDropdown">
                        <ul class="navbar-nav">
                            {%if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                            {# Main nav links — hidden on mobile (shown in bottom nav instead) #}
                            <li id="nav-messages" class="nav-item d-none d-lg-block">
                                <a class="nav-link" href="{{ path('app_message_board') }}">{{ 'messageboard.title'|trans }}</a>
                            </li>
                            <li id="nav-calendar" class="nav-item d-none d-lg-block">
                                <a class="nav-link" href="{{ path('app_booking_show') }}">{{ 'calendar'|trans }}</a>
                            </li>
                            <li id="nav-trips" class="nav-item d-none d-lg-block">
                                <a class="nav-link" href="{{ path('app_trip_list') }}">{{ 'trips.trips'|trans }}</a>
                            </li>
                            <li id="nav-expenses" class="nav-item d-none d-lg-block">
                                <a class="nav-link" href="{{ path('app_expense_list') }}">{{ 'expenses.expenses'|trans }}</a>
                            </li>
                            <li id="nav-payments" class="nav-item d-none d-lg-block">
                                <a class="nav-link" href="{{ path('app_payment_list') }}">{{ 'payments.payments'|trans }}</a>
                            </li>
                            <li id="nav-parking" class="nav-item d-none d-lg-block">
                                <a class="nav-link" href="{{ path('app_parking_show') }}">{{ 'parking.title'|trans }}</a>
                            </li>
                            <li id="nav-admin" class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                    {{ 'admin'|trans }}
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="{{ path('app_car_new') }}">{{ 'car.add'|trans }}</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_car_edit') }}">{{ 'car.manage'|trans }}</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_user_list') }}">{{ 'user.manage'|trans }}</a></li>
                                    {% if is_granted('ROLE_ADMIN') %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="{{ path('app_superadmin') }}">{{ 'superadmin.title'|trans }}</a></li>
                                    {% endif %}
                                </ul>
                            </li>
                            <li id="nav-user" class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                    {% if app.user.profilePicturePath|default %}
                                    <img class="rounded-circle"
                                        src="{{ asset('/uploads/users/' ~ app.user.profilePicturePath)|imagine_filter('profile_thumb') }}" alt="" height="30"
                                        width="30">
                                    {% else %}
                                    <img class="rounded-circle" src="{{ asset('./static/default-user.png') }}" alt=""
                                        height="30" width="30">
                                    {% endif %}{{ app.user.name }}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="{{ path('app_user_edit') }}">{{
                                            'user.profile.edit'|trans
                                            }}</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_logout') }}">{{
                                            'user.logout'|trans }}</a></li>
                                </ul>
                            </li>
                            {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">{{ 'user.login'|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_register') }}">{{ 'user.register'|trans }}</a>
                            </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main>
            <div class="flash-container container-fluid">
                {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('warning') %}
                <div class="alert alert-warning">{{ message }}</div>
                {% endfor %}
            </div>


            {% block body %}
            <div class="container-fluid mt-5">
                <div class="row">
                    {% block content_body %}
                    {% endblock %}
                </div>
            </div>
            {% endblock %}
        </main>

        <footer class="p-2 mt-5 d-none d-lg-block">
            <p>{{ 'sharing.is.caring'|trans }}!</p>
        </footer>
    </div>

    {# Mobile bottom navigation — hidden on lg and above #}
    {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
    {% set route = app.request.attributes.get('_route') %}
    <nav id="mobile-bottom-nav" class="d-lg-none fixed-bottom">
        <div class="d-flex">
            <a id="mobile-nav-messages" href="{{ path('app_message_board') }}"
               class="mobile-nav-item{% if route starts with 'app_message' %} active{% endif %}">
                <i class="fa-solid fa-comments"></i>
                <span>{{ 'messageboard.title'|trans }}</span>
            </a>
            <a id="mobile-nav-calendar" href="{{ path('app_booking_show') }}"
               class="mobile-nav-item{% if route == 'app_booking_show' %} active{% endif %}">
                <i class="fa-solid fa-calendar-days"></i>
                <span>{{ 'calendar'|trans }}</span>
            </a>
            <a id="mobile-nav-trips" href="{{ path('app_trip_list') }}"
               class="mobile-nav-item{% if route starts with 'app_trip' %} active{% endif %}">
                <i class="fa-solid fa-route"></i>
                <span>{{ 'trips.trips'|trans }}</span>
            </a>
            <a id="mobile-nav-expenses" href="{{ path('app_expense_list') }}"
               class="mobile-nav-item{% if route starts with 'app_expense' %} active{% endif %}">
                <i class="fa-solid fa-receipt"></i>
                <span>{{ 'expenses.expenses'|trans }}</span>
            </a>
            <a id="mobile-nav-payments" href="{{ path('app_payment_list') }}"
               class="mobile-nav-item{% if route starts with 'app_payment' %} active{% endif %}">
                <i class="fa-solid fa-credit-card"></i>
                <span>{{ 'payments.payments'|trans }}</span>
            </a>
            <a id="mobile-nav-parking" href="{{ path('app_parking_show') }}"
               class="mobile-nav-item{% if route == 'app_parking_show' %} active{% endif %}">
                <i class="fa-solid fa-square-parking"></i>
                <span>{{ 'parking.title'|trans }}</span>
            </a>
        </div>
    </nav>
    {% endif %}
</body>

</html>
