{% extends 'base.html.twig' %}

{% block content_body %}
<div class="col-xl-12 mt-5">
    <div class="d-flex align-items-center justify-content-between mb-3 page-header">
        <h4 class="mb-0">{{ 'trips.logbook'|trans }}</h4>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-outline-dark" onclick="location.href='{{ path('app_trip_new') }}';">{{ 'trips.add.new'|trans }} <span class="fa fa-plus-circle"></span></button>
            <form method="get" class="d-flex align-items-center gap-2">
                <label for="userFilter" class="mb-0 text-nowrap d-none d-lg-inline">{{ 'filter.user'|trans }}</label>
                <select name="user" id="userFilter" class="form-select form-select-sm" style="min-width: 10rem" onchange="this.form.submit()">
                    <option value="">{{ 'filter.all_users'|trans }}</option>
                    {% for u in carUsers %}
                        <option value="{{ u.id }}" {% if u.id == selectedUserId %}selected{% endif %}>{{ u.name }}</option>
                    {% endfor %}
                </select>
                <label for="yearFilter" class="mb-0 text-nowrap d-none d-lg-inline">{{ 'filter.year'|trans }}</label>
                <select name="year" id="yearFilter" class="form-select form-select-sm" style="min-width: 9rem" onchange="this.form.submit()">
                    <option value="">{{ 'filter.all_years'|trans }}</option>
                    {% for y in availableYears %}
                        <option value="{{ y }}" {% if y == selectedYear %}selected{% endif %}>{{ y }}</option>
                    {% endfor %}
                </select>
            </form>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead class="table-secondary">
                <tr>
                    <th class="text-center">{{ 'user.user'|trans }}</th>
                    <th class="text-center">{{ 'date.start'|trans }}</th>
                    <th class="text-center">{{ 'date.end'|trans }}</th>
                    <th class="text-center">{{ 'start'|trans }} {{ car.milageUnit }}</th>
                    <th class="text-center">{{ 'end'|trans }} {{ car. milageUnit }}</th>
                    <th class="text-center">{{ car.milageUnit }} {{ 'trips.driven'|trans }}</th>
                    <th class="text-center">{{ 'trips.type'|trans }}</th>
                    <th class="text-center">{{ 'costs'|trans }}</th>
                    <th class="text-center">{{ 'comment'|trans }}</th>
                    <th class="text-center">{{ 'status'|trans }}</th>
                    <th class="text-center">{{ 'actions'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for trip in pager %}
                    <tr>
                        <td class="text-center">
                            {% for user in trip.users %}{{ user.name }}{% if not loop.last %}, {% endif %}{% endfor %}
                            {% if trip.users|length > 1 or trip.users|first != trip.editor %}
                                <br/><span class="small">({{ 'author'|trans }}: {{ trip.editor.name }})</span>
                            {% endif %}
                        </td>
                        <td class="text-center">{{ trip.startDate|date('d.m.Y') }}</td>
                        <td class="text-center">{{ trip.endDate|date('d.m.Y') }}</td>
                        <td class="text-center">{{ trip.startMileage|number_format(0, ',', '.') }}</td>
                        <td class="text-center">{{ trip.endMileAge|number_format(0, ',', '.') }}</td>
                        <td class="text-center">{{ trip.mileage|number_format(0, ',', '.') }}</td>
                        <td class="text-center">{{ trip.type|trans }}</td>
                        <td class="text-center">{{ trip.costs|format_currency(car.currency, locale=app.user.locale)}}</td>
                        <td class="text-center">{{ trip.comment }}</td>
                        <td class="text-center">{% if trip.isCompleted() %}<i class="fas fa-square-check text-success"></i>{% else %}<i class="fa-regular fa-square text-muted"></i>{% endif %}</td>
                        <td class="text-center">
                        {% if loop.first %}
                            <a href='{{ path('app_trip_edit', {trip: trip.id}) }}' class="btn btn-outline-primary"><i class="fas fa-edit"></i></a>
                        {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr class="table-secondary fw-bold">
                    <td colspan="5" class="text-end">{{ 'filter.total'|trans }}</td>
                    <td class="text-center">{{ totals.mileage|number_format(0, ',', '.') }} {{ car.milageUnit }}</td>
                    <td></td>
                    <td class="text-center">{{ totals.costs|format_currency(car.currency, locale=app.user.locale) }}</td>
                    <td colspan="3"></td>
                </tr>
            </tfoot>
        </table>
    </div>
    {% if pager.haveToPaginate %}
    <div class="d-flex justify-content-center mb-3">
        {% set pagerParams = {} %}
        {% if selectedYear %}{% set pagerParams = pagerParams|merge({year: selectedYear}) %}{% endif %}
        {% if selectedUserId %}{% set pagerParams = pagerParams|merge({user: selectedUserId}) %}{% endif %}
        {{ pagerfanta(pager, 'twitter_bootstrap5', {routeName: 'app_trip_list', routeParams: pagerParams}) }}
    </div>
    {% endif %}
</div>
{% endblock %}
