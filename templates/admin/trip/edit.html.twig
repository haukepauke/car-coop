{% extends 'base.html.twig' %}

{% block content_body %}
<div class="col-xl-6 mt-5">
    <h4>{{ 'trips.edit.with'|trans }}</h4>

    {{ form_start(tripForm, { attr: { id: tripForm.vars.id } }) }}
        {{ form_widget(tripForm) }}
    {{ form_end(tripForm, {'render_rest': false}) }}

    <div class="d-flex flex-wrap gap-2 align-items-center mt-3">
        <button type="submit" form="{{ tripForm.vars.id }}" class="btn btn-outline-dark">{{ 'trips.edit.update'|trans }}</button>
        {% if trip.mileage > 1 %}
        <a href="{{ path('app_trip_split', {trip: trip.id}) }}" class="btn btn-outline-secondary">{{ 'trips.split'|trans }} <i class="fas fa-scissors"></i></a>
        {% endif %}

        {% if canDelete %}
        <form method="post" action="{{ path('app_trip_delete', {trip: trip.id}) }}" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('trip_delete_' ~ trip.id) }}">
            <button type="submit" class="btn btn-outline-danger">{{ 'trips.delete'|trans }} <i class="fas fa-trash"></i></button>
        </form>
        {% endif %}
    </div>
</div>
{% endblock %}
