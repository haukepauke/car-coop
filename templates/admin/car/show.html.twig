{% extends 'base.html.twig' %}

{% block content_body %}
<div class="mt-5">
    <div class="container-fluid">
        <h1 class="visually-hidden">{{ car ? car.name : 'car.data'|trans }}</h1>

        {# ── Guided tour banner ── #}
        {% if app.user.showWelcomeTour %}
        {% set tourConfig = {
            bannerTitle: 'tour.banner.title'|trans,
            bannerDesc: 'tour.banner.desc'|trans,
            startLabel: 'tour.banner.start'|trans,
            hideLabel: 'tour.banner.hide'|trans,
            progressText: 'tour.progress'|trans,
            nextLabel: 'tour.btn.next'|trans,
            prevLabel: 'tour.btn.prev'|trans,
            doneLabel: 'tour.btn.done'|trans,
            hideUrl: path('app_user_tour_hide'),
            hideToken: csrf_token('hide_tour_' ~ app.user.id),
            steps: [
                {
                    title: 'tour.welcome.title'|trans,
                    description: 'tour.welcome.desc'|trans({'%carImage%': asset('./static/default-car.png')}),
                },
                {
                    element: '.accordion-button',
                    title: 'tour.car.title'|trans,
                    description: 'tour.car.desc'|trans,
                    side: 'bottom',
                },
                {
                    element: '#tour-car-actions',
                    title: 'tour.actions.title'|trans,
                    description: 'tour.actions.desc'|trans,
                    side: 'bottom',
                },
                {
                    element: '.stat-grid',
                    title: 'tour.stats.title'|trans,
                    description: 'tour.stats.desc'|trans,
                    side: 'top',
                },
                {
                    element: '#tour-bookings',
                    title: 'tour.bookings.title'|trans,
                    description: 'tour.bookings.desc'|trans,
                    side: 'top',
                },
                {
                    element: '.chart-grid',
                    title: 'tour.charts.title'|trans,
                    description: 'tour.charts.desc'|trans,
                    side: 'top',
                },
                {
                    desktopElement: '#nav-messages',
                    mobileElement: '#mobile-nav-messages',
                    title: 'tour.nav.messages.title'|trans,
                    description: 'tour.nav.messages.desc'|trans,
                },
                {
                    desktopElement: '#nav-calendar',
                    mobileElement: '#mobile-nav-calendar',
                    title: 'tour.nav.calendar.title'|trans,
                    description: 'tour.nav.calendar.desc'|trans,
                },
                {
                    desktopElement: '#nav-trips',
                    mobileElement: '#mobile-nav-trips',
                    title: 'tour.nav.trips.title'|trans,
                    description: 'tour.nav.trips.desc'|trans,
                },
                {
                    desktopElement: '#nav-expenses',
                    mobileElement: '#mobile-nav-expenses',
                    title: 'tour.nav.expenses.title'|trans,
                    description: 'tour.nav.expenses.desc'|trans,
                },
                {
                    desktopElement: '#nav-payments',
                    mobileElement: '#mobile-nav-payments',
                    title: 'tour.nav.payments.title'|trans,
                    description: 'tour.nav.payments.desc'|trans,
                },
                {
                    desktopElement: '#nav-parking',
                    mobileElement: '#mobile-nav-parking',
                    title: 'tour.nav.parking.title'|trans,
                    description: 'tour.nav.parking.desc'|trans,
                },
                {
                    desktopElement: '#nav-admin',
                    title: 'tour.nav.admin.title'|trans,
                    description: 'tour.nav.admin.desc'|trans,
                    desktopOnly: true,
                    side: 'bottom',
                },
                {
                    desktopElement: '#nav-user',
                    title: 'tour.nav.user.title'|trans,
                    description: 'tour.nav.user.desc'|trans,
                    desktopOnly: true,
                    side: 'bottom',
                },
            ],
        } %}
        <div id="tour-banner" class="d-none tour-banner mb-4">
            <div class="tour-banner__icon"><i class="fa-solid fa-map"></i></div>
            <div class="tour-banner__body">
                <strong>{{ 'tour.banner.title'|trans }}</strong>
                <span class="text-muted">{{ 'tour.banner.desc'|trans }}</span>
            </div>
            <div class="tour-banner__actions">
                <button id="tour-start-btn" class="btn btn-sm btn-outline-dark">
                    <i class="fa-solid fa-play"></i> {{ 'tour.banner.start'|trans }}
                </button>
                <button id="tour-hide-btn" class="btn btn-sm btn-link text-muted">
                    {{ 'tour.banner.hide'|trans }}
                </button>
            </div>
        </div>
        <script type="application/json" id="tour-config">{{ tourConfig|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_QUOT'))|raw }}</script>
        {% endif %}

        <div class="accordion" id="carsAccordion">
        {% for carData in carPanels %}
            {% set carId = 'car-' ~ carData.car.id %}
            {% set isActive = carData.car.id == activeCarId %}
            {% set logoUrl = carData.car.profilePicturePath
                ? asset('/uploads/cars/' ~ carData.car.profilePicturePath)
                : asset('./static/default-car.png') %}
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading-{{ carId }}">
                    <button class="accordion-button {% if not isActive %}collapsed{% endif %}"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#collapse-{{ carId }}"
                            aria-expanded="{{ isActive ? 'true' : 'false' }}"
                            aria-controls="collapse-{{ carId }}"
                            data-car-id="{{ carData.car.id }}"
                            data-car-name="{{ carData.car.name }}"
                            data-car-logo="{{ logoUrl }}"
                            data-activate-url="{{ path('app_car_activate', {id: carData.car.id}) }}">
                        <img src="{{ logoUrl }}" alt="" width="30" height="30" class="rounded-circle me-2">
                        <strong class="text-truncate" style="max-width: 45vw;">{{ carData.car.name }}</strong>
                        {% if carData.car.licensePlate %}<span class="d-none d-sm-inline">&nbsp;&middot;&nbsp;{{ carData.car.licensePlate }}</span>{% endif %}
                    </button>
                </h2>
                <div id="collapse-{{ carId }}"
                     class="accordion-collapse collapse {% if isActive %}show{% endif %}"
                     aria-labelledby="heading-{{ carId }}"
                     data-bs-parent="#carsAccordion">
                    <div class="accordion-body">

                        {# ── Car data ── #}
                        <div class="d-flex justify-content-between align-items-center mb-3 page-header">
                            <h3 class="mb-0">{{ 'car.data'|trans }}</h3>
                            <div class="d-flex gap-2" id="tour-car-actions">
                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm js-trip-cost-estimate"
                                        data-bs-toggle="modal"
                                        data-bs-target="#tripCostCalculatorModal"
                                        data-car-name="{{ carData.car.name }}"
                                        data-estimate-url="{{ path('app_car_estimate_trip_costs', {car: carData.car.id}) }}">
                                    {{ 'trips.cost_calculator.open'|trans }}
                                </button>
                                <a href="{{ path('app_car_review') }}" class="btn btn-outline-primary btn-sm">
                                    &#9881; {{ 'car.review.button'|trans }}
                                </a>
                                <a href="{{ path('app_car_export_pdf') }}" class="btn btn-outline-secondary btn-sm">
                                    &#8659; {{ 'car.exportpdf.button'|trans }}
                                </a>
                            </div>
                        </div>
                        <div class="stat-grid">
                            {% if carData.car.licensePlate %}
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.form.licenseplate'|trans }}</span>
                                <span class="stat-card__value">{{ carData.car.licensePlate }}</span>
                            </div>
                            {% endif %}
                            {% if carData.car.vendor %}
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.form.vendor'|trans }}</span>
                                <span class="stat-card__value">{{ carData.car.vendor }}</span>
                            </div>
                            {% endif %}
                            {% if carData.car.make %}
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.form.make'|trans }}</span>
                                <span class="stat-card__value">{{ carData.car.make }}</span>
                            </div>
                            {% endif %}
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.mileage'|trans }}</span>
                                <span class="stat-card__value">{{ carData.car.mileage }} {{ carData.car.milageUnit }}</span>
                            </div>
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.season.mileage'|trans }} {{ "now"|date("Y") }}</span>
                                <span class="stat-card__value">{{ carData.distanceTravelled }} {{ carData.car.milageUnit }}</span>
                            </div>
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.season.spent'|trans }} {{ "now"|date("Y") }}</span>
                                <span class="stat-card__value">{{ carData.moneySpent }} {{ carData.car.currencySymbol }}
                                    <small class="fw-normal text-muted">({{ 'car.season.fuel'|trans }} {{ carData.moneySpentFuel }} {{ carData.car.currencySymbol }})</small>
                                </span>
                            </div>
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.costs.calculated_for_year'|trans({'%year%': 'now'|date('Y')}) }}</span>
                                <span class="stat-card__value">{{ carData.calculatedCostsPerUnit|number_format(3, '.', ',') }} {{ carData.car.currencySymbol }} / {{ carData.car.milageUnit }}</span>
                            </div>
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.costs.calculated_all_years'|trans }}</span>
                                <span class="stat-card__value">{{ carData.calculatedCostsPerUnitAllYears|number_format(3, '.', ',') }} {{ carData.car.currencySymbol }} / {{ carData.car.milageUnit }}</span>
                            </div>
                            {% if carData.car.fuelType %}
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.form.fueltype'|trans }}</span>
                                <span class="stat-card__value">{{ ('car.form.fueltype.' ~ carData.car.fuelType)|trans }}</span>
                            </div>
                            {% endif %}
                            {% if carData.car.fuelConsumption100 %}
                            <div class="stat-card">
                                <span class="stat-card__label">{{ 'car.form.fuelconsumption100'|trans }}</span>
                                <span class="stat-card__value">{{ carData.car.fuelConsumption100|number_format(1, '.', ',') }} l/100{{ carData.car.milageUnit }}</span>
                            </div>
                            {% endif %}
                        </div>

                        {# ── Next bookings ── #}
                        {% if carData.bookings|length > 0 %}
                        <div class="row pt-4" id="tour-bookings">
                            <div class="col"><h3>{{ 'car.bookings.next'|trans }}</h3></div>
                        </div>
                        <div class="table-responsive">
                            <table class="table mobile-data-table">
                                    <thead>
                                        <tr>
                                            <th scope="col">{{ 'date.start'|trans }}</th>
                                            <th scope="col">{{ 'date.end'|trans }}</th>
                                            <th scope="col">{{ 'user.user'|trans }}</th>
                                            <th scope="col">{{ 'booking.form.title'|trans }}</th>
                                            <th scope="col">{{ 'booking.form.status'|trans }}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    {% for booking in carData.bookings %}
                                        <tr>
                                            <td data-label="{{ 'date.start'|trans }}">{{ booking.getStartDate()|date("d.m.Y") }}</td>
                                            <td data-label="{{ 'date.end'|trans }}">{{ booking.getEndDate()|date("d.m.Y") }}</td>
                                            <td data-label="{{ 'user.user'|trans }}">{{ booking.getUser().getName() }}</td>
                                            <td data-label="{{ 'booking.form.title'|trans }}">{{ booking.getTitle() }}</td>
                                            <td data-label="{{ 'booking.form.status'|trans }}">{{ booking.getStatus()|trans }}</td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                        </div>
                        {% endif %}

                        {# ── Statistics (hidden on mobile) ── #}
                        <div class="statistics-section">
                            <div class="row pt-4">
                                <div class="col"><h3>{{ 'car.statistics'|trans }}</h3></div>
                            </div>
                            <div class="chart-grid">
                                <div class="chart">
                                    {{ render_chart(carData.distanceChart) }}
                                </div>
                                <div class="chart">
                                    {{ render_chart(carData.balanceChart) }}
                                </div>
                            </div>
                        </div>

                        <div class="statistics-mobile-section d-lg-none">
                            <div class="row pt-4">
                                <div class="col"><h3>{{ 'money.user.balance'|trans }}</h3></div>
                            </div>
                            <div class="mobile-balance-overview" aria-label="{{ 'money.user.balance'|trans }}">
                                {% for entry in carData.balanceOverview %}
                                    <div class="mobile-balance-overview__item">
                                        <div class="mobile-balance-overview__user">
                                            {% if entry.user.profilePicturePath|default %}
                                                <img class="mobile-balance-overview__avatar rounded-circle" src="{{ asset('/uploads/users/' ~ entry.user.profilePicturePath)|imagine_filter('profile_thumb') }}" alt="" width="40" height="40">
                                            {% else %}
                                                <img class="mobile-balance-overview__avatar rounded-circle" src="{{ asset('./static/default-user.png') }}" alt="" width="40" height="40">
                                            {% endif %}
                                            <div class="mobile-balance-overview__identity">
                                                <span class="mobile-balance-overview__name">{{ entry.user.name }}</span>
                                            </div>
                                        </div>
                                        <div class="mobile-balance-overview__amount {% if entry.balance > 0 %}is-positive{% elseif entry.balance < 0 %}is-negative{% endif %}">
                                            {{ entry.balance|format_currency(carData.car.currency, locale=app.user.locale) }}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                    </div>{# /accordion-body #}
                </div>{# /accordion-collapse #}
            </div>{# /accordion-item #}
        {% endfor %}
        </div>{# /accordion #}

    </div>
</div>

<div class="modal fade" id="tripCostCalculatorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tripCostCalculatorModalTitle">
                    {{ 'trips.cost_calculator.open'|trans }}
                    {% if calculatorCar is not null %} - {{ calculatorCar.name }}{% endif %}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'close'|trans }}"></button>
            </div>
            <div class="modal-body" id="tripCostCalculatorModalBody" data-current-action="{{ path('app_car_estimate_trip_costs', {car: calculatorCar.id}) }}">
                {% include 'admin/trip/_cost_calculator_form.html.twig' %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/car-show.css') }}">
{% endblock %}

{% block importmap %}{{ importmap(['app', 'tour']) }}{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module">
    import { Modal } from 'bootstrap';

    document.addEventListener('DOMContentLoaded', function () {
        const accordion = document.getElementById('carsAccordion');
        const modalElement = document.getElementById('tripCostCalculatorModal');
        const modalBody = document.getElementById('tripCostCalculatorModalBody');
        const modalTitle = document.getElementById('tripCostCalculatorModalTitle');
        if (!accordion) return;

        const brandImg  = document.getElementById('navbar-brand-img');
        const brandName = document.getElementById('navbar-brand-name');

        function activateCar(button) {
            const carId   = button.dataset.carId;
            const carName = button.dataset.carName;
            const carLogo = button.dataset.carLogo;
            const url     = button.dataset.activateUrl;

            fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });

            if (brandImg)  brandImg.src = carLogo;
            if (brandName) brandName.textContent = carName;
        }

        // Activate on expand
        accordion.addEventListener('show.bs.collapse', function (e) {
            const collapseEl = e.target;
            const headingId  = collapseEl.getAttribute('aria-labelledby');
            const heading    = document.getElementById(headingId);
            if (heading) activateCar(heading.querySelector('button'));
        });

        // Activate the initially open panel on page load
        const openButton = accordion.querySelector('.accordion-button:not(.collapsed)');
        if (openButton) activateCar(openButton);

        document.querySelectorAll('.js-trip-cost-estimate').forEach(function (button) {
            button.addEventListener('click', function () {
                modalBody.dataset.currentAction = button.dataset.estimateUrl;
                modalTitle.textContent = "{{ 'trips.cost_calculator.open'|trans }}" + ' - ' + button.dataset.carName;

                const form = modalBody.querySelector('form');
                if (form) {
                    form.action = button.dataset.estimateUrl;
                }
            });
        });

        document.addEventListener('submit', async function (event) {
            const form = event.target;
            if (!(form instanceof HTMLFormElement) || form.id !== 'trip-cost-calculator-form') {
                return;
            }

            event.preventDefault();

            const response = await fetch(form.action || modalBody.dataset.currentAction, {
                method: form.method,
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                },
            });

            const payload = await response.json();
            modalBody.innerHTML = payload.html;
            modalBody.dataset.currentAction = form.action || modalBody.dataset.currentAction;

            if (payload.carName) {
                modalTitle.textContent = "{{ 'trips.cost_calculator.open'|trans }}" + ' - ' + payload.carName;
            }

            Modal.getOrCreateInstance(modalElement).show();
        });
    });
    </script>
{% endblock %}
