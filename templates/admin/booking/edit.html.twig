{% extends 'base.html.twig' %}

{% block content_body %}
<div class="col-xl-6 mt-5">
    <h4>{{ 'booking.edit.for'|trans }}</h4>

    {% if overlappingBookings is not empty %}
    <div class="alert alert-warning">
        <p class="mb-2">{{ 'booking.overlap.inline'|trans({'%count%': overlappingBookings|length}) }}</p>
        <ul class="mb-0">
            {% for overlap in overlappingBookings %}
            <li>
                {{ overlap.startDate|date('Y-m-d H:i') }} – {{ overlap.endDate|date('Y-m-d H:i') }}
                · {{ overlap.user.name }}
                {% if overlap.title %}
                    · {{ overlap.title }}
                {% endif %}
            </li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    {{ form_start(bookingForm)}}
        {{ form_widget(bookingForm) }}

        <button type="submit" class="btn btn-outline-dark my-3">{{ 'booking.update'|trans }}</button>
        <button type="link" class="btn btn-outline-danger my-3" onclick="location.href='{{ path('app_booking_delete',  {booking: booking.id}) }}';return false;">{{ 'booking.delete'|trans }} <i class="fas fa-trash"></i></button>
    {{ form_end(bookingForm) }}
</div>
{% endblock %}
