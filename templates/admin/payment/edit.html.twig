{% extends 'base.html.twig' %}

{% block content_body %}
<div class="col-xl-6 mt-5">
    <h4>{{ 'payments.edit.for'|trans }}</h4>

    {{ form_start(paymentForm)}}
        {{ form_widget(paymentForm) }}

        <button type="submit" class="btn btn-outline-dark my-3">{{ 'payments.edit.update'|trans }}</button>
    {{ form_end(paymentForm) }}

    <form method="post" action="{{ path('app_payment_delete', {payment: payment.id}) }}" class="d-inline">
        <input type="hidden" name="_token" value="{{ csrf_token('payment_delete_' ~ payment.id) }}">
        <button type="submit" class="btn btn-outline-danger my-3">{{ 'payments.delete'|trans }} <i class="fas fa-trash text-danger"></i></button>
    </form>
</div>
{% endblock %}
