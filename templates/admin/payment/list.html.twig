{% extends 'base.html.twig' %}

{% block content_body %}
<div class="col-xl-12 mt-5">
    <div class="d-flex align-items-center justify-content-between mb-3 page-header">
        <h4 class="mb-0">{{ 'payments.payments'|trans }}</h4>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-outline-dark" onclick="location.href='{{ path('app_payment_new') }}';">{{ 'payments.add.new'|trans }} <span class="fa fa-plus-circle"></span></button>
            <form method="get" class="d-flex align-items-center gap-2">
                <label for="yearFilter" class="mb-0 text-nowrap d-none d-lg-inline">{{ 'filter.year'|trans }}</label>
                <select name="year" id="yearFilter" class="form-select form-select-sm" style="min-width: 9rem" onchange="this.form.submit()">
                    <option value="">{{ 'filter.all_years'|trans }}</option>
                    {% for y in availableYears %}
                        <option value="{{ y }}" {% if y == selectedYear %}selected{% endif %}>{{ y }}</option>
                    {% endfor %}
                </select>
            </form>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead class="table-secondary">
                <tr>
                    <th class="text-center">{{ 'date.date'|trans }}</th>
                    <th class="text-center">{{ 'from'|trans }}</th>
                    <th class="text-center">{{ 'to'|trans }}</th>
                    <th class="text-center">{{ 'amount'|trans }}</th>
                    <th class="text-center">{{ 'payments.type'|trans }}</th>
                    <th class="text-center">{{ 'comment'|trans }}</th>
                    <th class="text-center">{{ 'actions'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for payment in pager %}
                    <tr>
                        <td class="text-center">{{ payment.date|date('d.m.Y') }}</td>
                        <td class="text-center">{{ payment.fromUser.name }}</td>
                        <td class="text-center">{{ payment.toUser.name }}</td>
                        <td class="text-center">{{ payment.amount|format_currency(car.currency, locale=app.user.locale)}}</td>
                        <td class="text-center">{{ payment.type|trans }}</td>
                        <td class="text-center">{{ payment.comment }}</td>
                        <td class="text-center">
                            <a href='{{ path('app_payment_edit', {payment: payment.id}) }}' class="btn btn-outline-primary"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr class="table-secondary fw-bold">
                    <td colspan="3" class="text-end">{{ 'filter.total'|trans }}</td>
                    <td class="text-center">{{ total|format_currency(car.currency, locale=app.user.locale) }}</td>
                    <td colspan="3"></td>
                </tr>
            </tfoot>
        </table>
    </div>
    {% if pager.haveToPaginate %}
    <div class="d-flex justify-content-center mb-3">
        {% set pagerParams = selectedYear ? {year: selectedYear} : {} %}
        {{ pagerfanta(pager, 'twitter_bootstrap5', {routeName: 'app_payment_list', routeParams: pagerParams}) }}
    </div>
    {% endif %}
</div>
{% endblock %}
