{% extends 'base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('vendor/leaflet/dist/leaflet.min.css') }}">
<link rel="stylesheet" href="{{ asset('styles/parking.css') }}">
{% endblock %}

{% block javascripts %}
{% block importmap %}{{ importmap(['app', 'parking']) }}{% endblock %}
{% endblock %}

{% block content_body %}
<div class="col-xl-8 mt-5">
    <h1 class="h4">{{ 'parking.title'|trans }}</h1>

    {% if location %}
    <p class="text-muted">
        {{ 'parking.recorded_at'|trans }} {{ location.createdAt|format_datetime('medium', 'short', locale=app.user.locale) }} {{ 'parking.recorded_by'|trans }} {{ location.user.name }}
    </p>
    {% endif %}

    <p class="text-muted">{{ 'parking.click_to_set'|trans }}</p>

    <div class="d-lg-none mb-3">
        <button type="button"
                id="parking-current-location-btn"
                class="btn btn-outline-dark w-100">
            <i class="fa-solid fa-location-crosshairs me-2"></i>{{ 'parking.use_current_location'|trans }}
        </button>
        <div id="parking-location-status" class="form-text text-muted mt-2"></div>
    </div>

    <div class="parking-map-shell is-loading">
        <div id="parking-map"
             role="region"
             aria-label="{{ 'parking.title'|trans }}"
             data-lat="{{ location.latitude ?? '' }}"
             data-lng="{{ location.longitude ?? '' }}"
             data-label="{{ car.name }}"
             data-save-url="{{ path('app_parking_save') }}"
             data-csrf-token="{{ csrf_token('parking_save') }}"
             data-marker-icon="{{ asset('vendor/leaflet/dist/images/marker-icon.png') }}"
             data-locating-label="{{ 'parking.locating'|trans }}"
             data-location-captured-label="{{ 'parking.location_captured'|trans }}"
             data-location-error-label="{{ 'parking.location_error'|trans }}"
             data-geolocation-unavailable-label="{{ 'parking.geolocation_unavailable'|trans }}"
             ></div>
        <div class="parking-map-loading" aria-hidden="true">
            <div class="parking-map-loading__card">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span>{{ 'parking.map_loading'|trans }}</span>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column flex-lg-row gap-2 mt-3">
        <a id="parking-navigate-btn"
           href="#"
           class="btn btn-outline-primary{% if not location %} d-none{% endif %}">
            <i class="fa-solid fa-route me-2"></i>{{ 'parking.navigate_to_vehicle'|trans }}
        </a>

        <form id="parking-save-form" method="post" action="{{ path('app_parking_save') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('parking_save') }}">
        <input type="hidden" name="lat" id="parking-save-lat">
        <input type="hidden" name="lng" id="parking-save-lng">
        <button type="submit" id="parking-save-btn" class="btn btn-outline-dark d-none">
            {{ 'parking.save_location'|trans }}
        </button>
        </form>
    </div>
</div>
{% endblock %}
