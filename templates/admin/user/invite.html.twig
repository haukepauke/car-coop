{% extends 'base.html.twig' %}

{% set activeGroups = car.userTypes|filter(ut => ut.active) %}
{% set singleGroup = activeGroups|length == 1 %}

{% block content_body %}
<div class="col-xl-6 mt-5">
    <h4>{{ 'invitation.invite'|trans }}</h4>

    {{ form_start(invitationForm) }}

    <div id="invite-entries"
         data-prototype="{{ form_widget(invitationForm.entries.vars.prototype)|e('html_attr') }}"
         data-single-group="{{ singleGroup ? '1' : '0' }}"
         data-entry-class="invite-entry border rounded p-3 mb-2">
      {% for entry in invitationForm.entries %}
      <div class="invite-entry border rounded p-3 mb-2">
        <div class="mb-2">
          {{ form_label(entry.email) }}
          {{ form_widget(entry.email, {'attr': {'class': 'form-control'}}) }}
          {{ form_errors(entry.email) }}
        </div>
        {% if not singleGroup %}
        <div class="mb-1">
          {{ form_label(entry.userType) }}
          {{ form_widget(entry.userType, {'attr': {'class': 'form-select'}}) }}
          {{ form_errors(entry.userType) }}
        </div>
        {% else %}
        <div hidden>{{ form_widget(entry.userType) }}</div>
        {% endif %}
        <div class="mb-1">
          {{ form_label(entry.locale) }}
          {{ form_widget(entry.locale, {'attr': {'class': 'form-select form-select-sm'}}) }}
        </div>
      </div>
      {% endfor %}
    </div>

    <button type="button" id="add-invite-entry" class="btn btn-outline-secondary w-100 mb-3">
        <i class="fa-solid fa-plus me-1"></i>{{ 'invitation.invite_another'|trans }}
    </button>

    <button type="submit" class="btn btn-outline-dark">{{ 'invitation.invite'|trans }}</button>

    {{ form_end(invitationForm) }}
</div>
{% endblock %}

{% block importmap %}{{ importmap(['app', 'invite']) }}{% endblock %}
