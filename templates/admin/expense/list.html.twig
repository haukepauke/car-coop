{% extends 'base.html.twig' %}

{% block content_body %}
<div class="col-xl-12 mt-5">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0">{{ 'expenses.for'|trans }} {{ car.name }}</h4>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-outline-dark" onclick="location.href='{{ path('app_expense_new') }}';">{{ 'expenses.add.new'|trans }} <span class="fa fa-plus-circle"></span></button>
            <form method="get" class="d-flex align-items-center gap-2">
                <label for="userFilter" class="mb-0 text-nowrap">{{ 'filter.user'|trans }}</label>
                <select name="user" id="userFilter" class="form-select form-select-sm" style="min-width: 10rem" onchange="this.form.submit()">
                    <option value="">{{ 'filter.all_users'|trans }}</option>
                    {% for u in carUsers %}
                        <option value="{{ u.id }}" {% if u.id == selectedUserId %}selected{% endif %}>{{ u.name }}</option>
                    {% endfor %}
                </select>
                <label for="yearFilter" class="mb-0 text-nowrap">{{ 'filter.year'|trans }}</label>
                <select name="year" id="yearFilter" class="form-select form-select-sm" style="min-width: 9rem" onchange="this.form.submit()">
                    <option value="">{{ 'filter.all_years'|trans }}</option>
                    {% for y in availableYears %}
                        <option value="{{ y }}" {% if y == selectedYear %}selected{% endif %}>{{ y }}</option>
                    {% endfor %}
                </select>
            </form>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead class="table-secondary">
                <tr>
                    <th class="text-center">{{ 'user.user'|trans }}</th>
                    <th class="text-center">{{ 'date.date'|trans }}</th>
                    <th class="text-center">{{ 'expenses.type'|trans }}</th>
                    <th class="text-center">{{ 'expenses.name'|trans }}</th>
                    <th class="text-center">{{ 'amount'|trans }}</th>
                    <th class="text-center">{{ 'comment'|trans }}</th>
                    <th class="text-center">{{ 'actions'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for expense in pager %}
                    <tr>
                        <td class="text-center">
                            {{ expense.user.name }}
                            {% if expense.user != expense.editor %}
                                <br/><span class="small">({{ 'author'|trans }}: {{ expense.editor.name }})</span>
                            {% endif %}
                        </td>
                        <td class="text-center">{{ expense.date|date('d.m.Y') }}</td>
                        <td class="text-center">{{ expense.type|trans }}</td>
                        <td class="text-center">{{ expense.name}}</td>
                        <td class="text-center">{{ expense.amount|format_currency('EUR', locale=app.user.locale )}}</td>
                        <td class="text-center">{{ expense.comment }}</td>
                        <td class="text-center">
                            <a href='{{ path('app_expense_edit', {expense: expense.id}) }}' class="btn btn-outline-primary"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr class="table-secondary fw-bold">
                    <td colspan="4" class="text-end">{{ 'filter.total'|trans }}</td>
                    <td class="text-center">{{ total|format_currency('EUR', locale=app.user.locale) }}</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>
    </div>
    {% if pager.haveToPaginate %}
    <div class="d-flex justify-content-center mb-3">
        {% set pagerParams = {} %}
        {% if selectedYear %}{% set pagerParams = pagerParams|merge({year: selectedYear}) %}{% endif %}
        {% if selectedUserId %}{% set pagerParams = pagerParams|merge({user: selectedUserId}) %}{% endif %}
        {{ pagerfanta(pager, 'twitter_bootstrap5', {routeName: 'app_expense_list', routeParams: pagerParams}) }}
    </div>
    {% endif %}
</div>
{% endblock %}
