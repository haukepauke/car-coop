{% extends 'base.html.twig' %}

{% block title %}{{ 'messageboard.title'|trans }} – {{ car.name }}{% endblock %}

{% block importmap %}{{ importmap(['app', 'messageboard']) }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('vendor/quill/dist/quill.snow.css') }}">
<link rel="stylesheet" href="{{ asset('styles/messageboard.css') }}">
{% endblock %}

{% block content_body %}
<div class="col-12 mt-5">
    <div class="d-flex align-items-center justify-content-between mb-3 page-header">
        <h4 class="mb-0">{{ 'messageboard.title'|trans }}</h4>
        <form method="get" class="d-flex align-items-center gap-2">
            <label for="yearFilter" class="mb-0 text-nowrap d-none d-lg-inline">{{ 'filter.year'|trans }}</label>
            <select name="year" id="yearFilter" class="form-select form-select-sm" style="min-width: 9rem" onchange="this.form.submit()">
                <option value="">{{ 'filter.all_years'|trans }}</option>
                {% for y in availableYears %}
                    <option value="{{ y }}" {% if y == selectedYear %}selected{% endif %}>{{ y }}</option>
                {% endfor %}
            </select>
        </form>
    </div>

    <p class="text-muted small">{{ 'messageboard.total_messages'|trans({'%count%': totalMessages}) }}</p>

    {# Flash messages #}
    {% for label, flashes in app.flashes(['warning', 'danger']) %}
        {% for msg in flashes %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ msg|trans }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'close'|trans }}"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Messages list #}
    {% for message in pager %}
    <div class="card mb-3 {% if message.isBroadcast %}border-danger{% elseif message.isSticky %}border-warning{% endif %}">
        <div class="card-header d-flex justify-content-between align-items-center {% if message.isSticky and not message.isBroadcast %}bg-warning bg-opacity-10{% endif %}">
            <div class="d-flex align-items-center gap-2">
                {% if message.isSticky and not message.isBroadcast %}
                <i class="fa-solid fa-thumbtack text-warning"></i>
                {% endif %}
                <strong>
                    {% if message.isBroadcast %}
                        <span class="text-danger"><i class="fa-solid fa-bullhorn"></i> {{ 'messageboard.server_admin'|trans }}:
                        {{ message.author ? message.author.name : 'ServerAdmin' }}</span>
                    {% elseif message.author %}
                        {{ message.author.name }}
                    {% else %}
                        <i class="fa-solid fa-robot"></i> {{ 'messageboard.system'|trans }}
                    {% endif %}
                </strong>
                <small class="text-muted">{{ message.createdAt|format_datetime('medium', 'short', locale=app.user.locale) }}</small>
            </div>
            {% if not message.isBroadcast %}
            <div class="d-flex gap-2">
                {# Sticky toggle — any user #}
                <form method="post" action="{{ path('app_message_toggle_sticky', {id: message.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('message_sticky_' ~ message.id) }}">
                    <button type="submit" class="btn btn-sm {% if message.isSticky %}btn-warning{% else %}btn-outline-secondary{% endif %}" title="{{ 'messageboard.toggle_sticky'|trans }}" aria-label="{{ 'messageboard.toggle_sticky'|trans }}">
                        <i class="fa-solid fa-thumbtack"></i>
                    </button>
                </form>
                {# Delete — author or admin only #}
                {% if message.author == app.user or car.isAdminUser(app.user) %}
                <button type="button" class="btn btn-sm btn-outline-danger js-confirm-delete"
                        title="{{ 'messageboard.delete'|trans }}"
                        aria-label="{{ 'messageboard.delete'|trans }}"
                        data-action="{{ path('app_message_delete', {id: message.id}) }}"
                        data-token="{{ csrf_token('message_delete_' ~ message.id) }}"
                        data-message="{{ 'messageboard.delete_confirm'|trans }}">
                    <i class="fa-solid fa-trash"></i>
                </button>
                {% endif %}
            </div>
            {% endif %}
        </div>
        <div class="card-body">
            {% if message.systemData %}
                {{ message.systemData.key|trans(message.systemData.params)|raw }}
            {% else %}
                {% if message.content %}
                    {{ message.content|sanitize_html }}
                {% endif %}
                {% if message.photos %}
                <div class="d-flex flex-wrap gap-2 mt-2">
                    {% for photo in message.photos %}
                    <img src="{{ asset('uploads/messages/' ~ photo) }}"
                         alt="{{ 'messageboard.photo'|trans }}"
                         class="message-photo-thumb"
                         data-photo-url="{{ asset('uploads/messages/' ~ photo) }}"
                         data-photo-name="{{ photo }}"
                         onclick="openPhotoModal(this)">
                    {% endfor %}
                </div>
                {% endif %}
            {% endif %}
        </div>
    </div>
    {% else %}
    <p class="text-muted">{{ 'messageboard.no_messages'|trans }}</p>
    {% endfor %}

    {% if pager.haveToPaginate %}
    <div class="d-flex justify-content-center mb-4">
        {% set pagerParams = selectedYear ? {year: selectedYear} : {} %}
        {{ pagerfanta(pager, 'twitter_bootstrap5', {routeName: 'app_message_board', routeParams: pagerParams}) }}
    </div>
    {% endif %}

    {# New message form #}
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">{{ 'messageboard.new_message'|trans }}</h5>
            <div id="quill-editor" style="min-height: 120px;"></div>
            <form id="message-form" method="post" action="{{ path('app_message_new') }}" class="mt-2" enctype="multipart/form-data">
                <input type="hidden" name="_token" value="{{ csrf_token('message_new') }}">
                <input type="hidden" name="content" id="message-content">
                <input type="file" name="photos[]" id="message-photos" accept="image/*" multiple class="d-none">
                <div id="photo-preview-area" class="photo-upload-area" title="{{ 'messageboard.photo_hint'|trans }}">
                    <button type="button" id="photo-add-btn" class="photo-add-btn" title="{{ 'messageboard.attach_photos'|trans }}" aria-label="{{ 'messageboard.attach_photos'|trans }}">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </div>
                <button type="submit" class="btn btn-outline-dark mt-2">{{ 'messageboard.post'|trans }}</button>
            </form>
        </div>
    </div>
</div>

{# Fullscreen photo modal #}
<div class="modal fade" id="photoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-dark">
            <div class="modal-header border-0 pb-1">
                <div class="d-flex gap-2 ms-auto">
                    <a id="photoDownloadBtn" href="#" download class="btn btn-sm btn-outline-light">
                        <i class="fa-solid fa-download"></i> {{ 'messageboard.download_photo'|trans }}
                    </a>
                    <button type="button" class="btn btn-sm btn-outline-light" data-bs-dismiss="modal">
                        <i class="fa-solid fa-xmark"></i> {{ 'messageboard.close'|trans }}
                    </button>
                </div>
            </div>
            <div class="modal-body pt-0 text-center">
                <img id="photoModalImg" src="" alt="">
            </div>
        </div>
    </div>
</div>

{# ── Shared confirm modal ──────────────────────────────────────────────────── #}
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ 'confirm_delete_title'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'close'|trans }}"></button>
            </div>
            <div class="modal-body" id="confirmModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'cancel'|trans }}</button>
                <form id="confirmModalForm" method="post">
                    <input type="hidden" name="_token" id="confirmModalToken">
                    <button type="submit" class="btn btn-danger">{{ 'delete'|trans }}</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    const modal = document.getElementById('confirmModal');
    modal.addEventListener('show.bs.modal', function (e) {
        const btn = e.relatedTarget;
        document.getElementById('confirmModalBody').textContent  = btn.dataset.message;
        document.getElementById('confirmModalForm').action       = btn.dataset.action;
        document.getElementById('confirmModalToken').value       = btn.dataset.token;
    });

    document.querySelectorAll('.js-confirm-delete').forEach(function (btn) {
        btn.dataset.bsToggle  = 'modal';
        btn.dataset.bsTarget  = '#confirmModal';
    });
}());
</script>
{% endblock %}
